---
import BaseLayout from '../layouts/BaseLayout.astro';
import EbookImage from '../assets/hero-ebook.jpg';

const SITE_URL = 'https://blog-renda-extra.vercel.app';

const faqItems = [
  {
    question: 'Quem trabalha CLT pode ter renda extra?',
    answer: 'Sim. Trabalhar com carteira assinada não impede você de ter outras fontes de renda. O ebook mostra como fazer isso de forma legal, no seu tempo livre, sem conflito com seu emprego atual.',
  },
  {
    question: 'Preciso investir dinheiro para começar?',
    answer: 'Não. O método apresentado no ebook foi pensado para quem ainda não tem capital para investir. Você começa com o que já tem: tempo, conhecimento e acesso à internet.',
  },
  {
    question: 'Preciso aparecer nas redes sociais?',
    answer: 'Não. Nenhuma das estratégias do ebook exige que você apareça em vídeos ou se exponha publicamente. Tudo pode ser feito de forma anônima se preferir.',
  },
  {
    question: 'Quanto tempo por dia preciso dedicar?',
    answer: 'O plano foi desenhado para quem tem entre 30 minutos e 1 hora por dia disponível. Você encaixa nas manhãs, pausas do trabalho ou depois do jantar.',
  },
  {
    question: 'O ebook é realmente gratuito?',
    answer: 'Sim, 100% gratuito. Sem taxa, sem cobrança futura, sem cartão de crédito. Você preenche o formulário e recebe o material diretamente no seu email.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const bookSchema = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: 'Como Construir Sua Primeira Escada de Renda Paralela em 21 Dias Sem Pedir Demissão',
  description: 'Descubra como criar novas fontes de renda mesmo trabalhando o dia inteiro, sem precisar pedir demissão, investir muito dinheiro ou aparecer na internet.',
  author: {
    '@type': 'Organization',
    name: 'Renda Extra na Prática',
  },
  url: `${SITE_URL}/ebook`,
  inLanguage: 'pt-BR',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
  },
};
---

<BaseLayout
  title="Ebook Gratuito | Escada de Renda Paralela em 21 Dias"
  description="Baixe gratuitamente o ebook Escada de Renda Paralela em 21 Dias e descubra como criar novas fontes de renda sem abandonar seu emprego atual."
  image={EbookImage}
  keywords={['ebook gratuito renda extra', 'renda paralela clt', 'como ter renda extra', 'renda extra sem aparecer', 'renda extra sem investimento']}
>
  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(bookSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ── HERO ── -->
  <section class="hero-gradient py-20 px-4">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-full border border-accent/30 bg-accent-subtle px-4 py-1.5 text-sm font-medium text-accent mb-6">
        📘 Ebook Gratuito
      </span>
      <h1 class="font-serif text-4xl font-bold text-fg leading-tight mb-6 text-balance md:text-5xl">
        Como Construir Sua Primeira Escada de Renda Paralela em 21 Dias Sem Pedir Demissão
      </h1>
      <p class="text-muted text-lg leading-relaxed mb-8 max-w-2xl mx-auto">
        Descubra como criar novas entradas de dinheiro mesmo trabalhando o dia inteiro, sem depender de sorte, investimento alto ou fórmulas milagrosas.
      </p>
      <a
        href="#formulario"
        class="inline-block rounded-lg bg-accent px-8 py-4 text-base font-semibold text-white transition-colors duration-200 hover:bg-accent-hover"
      >
        Quero Receber o Ebook
      </a>
    </div>
  </section>

  <!-- ── BENEFÍCIOS ── -->
  <section class="py-16 px-4 bg-bg-elevated">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-serif text-2xl font-semibold text-fg text-center mb-10">
        O que você vai encontrar no ebook
      </h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {[
          { icon: '✅', text: 'Método 3 Fontes Invisíveis™' },
          { icon: '✅', text: 'Plano prático de 21 dias' },
          { icon: '✅', text: 'Exercícios de aplicação imediata' },
          { icon: '✅', text: 'Ideal para quem trabalha CLT' },
          { icon: '✅', text: 'Não exige investimento alto' },
          { icon: '✅', text: 'Não precisa aparecer nas redes sociais' },
        ].map((item) => (
          <div class="flex items-start gap-3 rounded-lg border border-border bg-bg-card p-4">
            <span class="text-xl">{item.icon}</span>
            <span class="text-fg font-medium">{item.text}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PROVA SOCIAL ── -->
  <section class="py-16 px-4">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-serif text-2xl font-semibold text-fg text-center mb-10">
        Para quem este ebook foi criado
      </h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {[
          { icon: '👨‍💼', title: 'Trabalhadores CLT', desc: 'Que querem renda extra sem pedir demissão' },
          { icon: '👩‍💻', title: 'Quem busca renda online', desc: 'Mas não sabe por onde começar' },
          { icon: '📈', title: 'Quem quer aumentar a renda', desc: 'Sem depender só do salário mensal' },
          { icon: '💡', title: 'Quem quer começar do zero', desc: 'Sem experiência prévia em negócios' },
        ].map((card) => (
          <div class="rounded-lg border border-border bg-bg-card p-5">
            <div class="text-3xl mb-3">{card.icon}</div>
            <h3 class="font-serif font-semibold text-fg mb-1">{card.title}</h3>
            <p class="text-muted text-sm">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FORMULÁRIO ── -->
  <section id="formulario" class="py-16 px-4 bg-bg-elevated">
    <div class="mx-auto max-w-lg">
      <div class="rounded-xl border border-border bg-bg-card p-8">
        <h2 class="font-serif text-2xl font-semibold text-fg text-center mb-2">
          Receba o ebook gratuitamente
        </h2>
        <p class="text-muted text-center text-sm mb-8">
          Preencha os campos abaixo e o ebook será enviado para o seu email.
        </p>

        <!-- Formulário com fetch para Formspree + redirecionamento via JS -->
        <form id="ebook-form" class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-fg mb-1.5">
              Seu melhor email <span class="text-accent" aria-hidden="true">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="voce@email.com"
              aria-required="true"
              class="w-full rounded-lg border border-border bg-bg px-4 py-3 text-fg placeholder:text-subtle focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors duration-200"
            />
            <p id="email-error" class="mt-1.5 text-sm text-red-400 hidden">Email inválido.</p>
          </div>
          <button
            type="submit"
            id="submit-btn"
            class="w-full rounded-lg bg-accent px-6 py-4 text-base font-semibold text-white transition-all duration-200 hover:bg-accent-hover active:scale-95"
          >
            Receber Ebook Gratuitamente
          </button>
        </form>

        <script>
          document.getElementById('ebook-form').addEventListener('submit', function(e) {
            e.preventDefault();
            var email = document.getElementById('email').value;
            var error = document.getElementById('email-error');
            var btn = document.getElementById('submit-btn');

            if (!email || !/^[^@]+@[^@]+\.[^@]+$/.test(email)) {
              error.classList.remove('hidden');
              return;
            }

            error.classList.add('hidden');
            btn.disabled = true;
            btn.textContent = 'Enviando...';

            fetch('https://formspree.io/f/xnjywnqd', {
              method: 'POST',
              headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
              body: JSON.stringify({ email: email, _subject: 'Novo lead - Ebook Renda Extra' })
            })
            .then(function() {
              window.location.href = '/obrigado';
            })
            .catch(function() {
              window.location.href = '/obrigado';
            });
          });
        </script>

        <p class="text-center text-xs text-subtle mt-4">
          🔒 Seus dados estão seguros. Sem spam.
        </p>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="py-16 px-4">
    <div class="mx-auto max-w-2xl">
      <h2 class="font-serif text-2xl font-semibold text-fg text-center mb-10">
        Perguntas frequentes
      </h2>
      <div class="space-y-4">
        {faqItems.map((item) => (
          <details class="group rounded-lg border border-border bg-bg-card">
            <summary class="flex cursor-pointer items-center justify-between p-5 font-medium text-fg list-none">
              <span>{item.question}</span>
              <span class="ml-4 shrink-0 text-accent transition-transform duration-200 group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <div class="px-5 pb-5 text-muted text-sm leading-relaxed">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>


